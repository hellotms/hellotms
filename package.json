{
  "name": "hellotms-marketing-solution",
  "version": "1.0.1",
  "private": true,
  "description": "Marketing Solution - Events Management System for themarketingsolution.com.bd",
  "scripts": {
    "dev": "pnpm run --parallel dev",
    "dev:admin": "pnpm --filter @hellotms/admin dev",
    "dev:public": "pnpm --filter @hellotms/public dev",
    "dev:api": "pnpm --filter @hellotms/api dev",
    "build": "pnpm --filter @hellotms/public build",
    "build:all": "pnpm run --parallel build",
    "build:shared": "pnpm --filter @hellotms/shared build",
    "build:admin": "pnpm --filter @hellotms/admin build",
    "build:admin:win": "pnpm --filter @hellotms/admin run build-win",
    "sign:admin:win": "pnpm --filter @hellotms/admin run sign-win",
    "build:admin:signed": "pnpm --filter @hellotms/admin run build-signed",
    "build:public": "pnpm --filter @hellotms/public build",
    "build:api": "pnpm --filter @hellotms/api build",
    "typecheck": "pnpm run --parallel typecheck",
    "lint": "pnpm run --parallel lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "clean": "pnpm run --parallel clean && rimraf node_modules"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "cross-env": "^10.1.0",
    "prettier": "^3.8.3",
    "rimraf": "^5.0.10",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver",
      "workerd",
      "@next/swc-win32-x64-msvc"
    ]
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.104.1"
  }
}
