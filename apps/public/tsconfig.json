{
  "compilerOptions": {
    "extends": "../../tsconfig.base.json",
    "lib": ["dom", "dom.iterable", "esnext"],
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"],
      "@hellotms/shared": ["../../packages/shared/src/index.ts"]
