{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "HelloTMS Admin",
  "version": "0.1.1",
  "identifier": "bd.com.themarketingsolution.admin",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm run dev",
    "beforeBuildCommand": "pnpm run build"
  },
  "app": {
    "windows": [
      {
        "title": "HelloTMS Admin",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "RWSRF/+NoH8Q1iRMRDi26SZW2LhBssWWoLbTQaFUNONSUzasHInsUv0q",
      "endpoints": [
        "https://hellotms-api.info-tms2021.workers.dev/apps/latest/update.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "publisher": "The Marketing Solution",
    "copyright": "Copyright © 2024 The Marketing Solution. All rights reserved.",
    "shortDescription": "TMS Admin App",
    "longDescription": "Official administrative desktop interface for The Marketing Solution (TMS).",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
