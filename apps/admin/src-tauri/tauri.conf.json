{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "tms-Portal",
  "version": "0.1.5",
  "identifier": "bd.com.themarketingsolution.admin",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm run dev",
    "beforeBuildCommand": "pnpm run build"
  },
  "app": {
    "windows": [
      {
        "title": "tms-INSIDE",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "maximized": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://api.themarketingsolution.com.bd/apps/latest/update.json"
      ],
      "pubkey": "UlcLtpTo3vXvYIndy5NXIXHPx213AMLcDoSr2mpbw6JJbb770NRV3R70B"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "The Marketing Solution"
  }
}