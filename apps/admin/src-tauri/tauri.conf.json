{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "tms-Portal",
  "version": "0.1.4",
  "identifier": "bd.com.themarketingsolution.admin",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm run dev",
    "beforeBuildCommand": "pnpm run build"
  },
  "app": {
    "windows": [
      {
        "title": "tms-INSIDE",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://hellotms-api.info-tms2021.workers.dev/apps/latest/update.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg5MzVDNDFGNjhFM0ZGODUKUldTRi8rTm9IOFExaVJNUkRpMjZTWlcyTGhCc3NXV29MYlRRYUZVTk9OU1pVc2FzSEluc1V2MHEK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "The Marketing Solution"
  }
}